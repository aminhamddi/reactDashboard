# =============================================================================
# OEE Audit Dashboard — Configuration
# =============================================================================
# Pour le déploiement intranet (tout sur le même serveur) :
#   - Laissez VIDE ou ne pas définir → auto-détection via window.location.origin
#
# Pour un déploiement séparé (dashboard sur une autre machine) :
#   - Définir VITE_API_URL avec l'IP du serveur backend

# Backend API URL (laisser vide pour auto-détection intranet)
VITE_API_URL=

# WebSocket host (laisser vide pour auto-détection)
VITE_WS_HOST=
